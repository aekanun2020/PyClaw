# --- LLM backend (OpenRouter, same as EliteClaw) ---
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
PYCLAW_DEFAULT_MODEL=anthropic/claude-3.7-sonnet

# --- Runtime (Layer 0) ---
PYCLAW_MAX_TOOL_ROUNDS=20
PYCLAW_HITL_TIMEOUT_SECONDS=60

# --- MCP servers (EliteClaw-compatible) ---
# PyClaw connects to these on `pyclaw run` and registers their tools.
# Numbered form (add as many as you like): MCP_SERVER_<N>_*
#   _URL       (required) server endpoint. A URL ending in /mcp is auto-detected
#              as Streamable HTTP; anything else defaults to classic SSE.
#              For a classic-SSE server point _URL at its event-stream path
#              (usually .../sse) — NOT the bare host:port, whose root often only
#              answers GET and will 405 on the MCP handshake.
#   _NAME      friendly name (used in logs)
#   _PREFIX    tool-name prefix to avoid collisions across servers (e.g. db_)
#   _TRANSPORT optional override: sse | streamable-http | http
#   _TIMEOUT   optional, milliseconds (EliteClaw style)
#   _HOST      optional, sent as the Host header
#
# MCP_SERVER_1_URL=http://127.0.0.1:9000/sse   # classic SSE -> point at /sse
# MCP_SERVER_1_NAME=mssql
# MCP_SERVER_1_PREFIX=db_
#
# MCP_SERVER_2_URL=http://127.0.0.1:8100/mcp
# MCP_SERVER_2_NAME=pdpa
# MCP_SERVER_2_PREFIX=pdpa_
#
# REQUEST_TIMEOUT=30000   # default timeout (ms) for servers without _TIMEOUT

# --- Optional: self-hosted deterministic inference ---
# For reproducible inference set these on your vLLM/SGLang server, not here:
#   vLLM:   VLLM_BATCH_INVARIANT=1
#   SGLang: --enable-deterministic-inference
