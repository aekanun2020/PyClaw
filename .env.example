# --- LLM backend (OpenRouter, same as EliteClaw) ---
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
PYCLAW_DEFAULT_MODEL=anthropic/claude-3.7-sonnet

# --- Runtime (Layer 0) ---
PYCLAW_MAX_TOOL_ROUNDS=20
PYCLAW_HITL_TIMEOUT_SECONDS=60

# --- Optional: self-hosted deterministic inference ---
# For reproducible inference set these on your vLLM/SGLang server, not here:
#   vLLM:   VLLM_BATCH_INVARIANT=1
#   SGLang: --enable-deterministic-inference
